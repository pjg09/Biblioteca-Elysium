' Director (usa interfaces de builders)
class DirectorCreacion {
    +construirEstudianteBasico(builder: IBuilderUsuario, nombre: string, email: string, carrera: string)
    +construirProfesorInvestigador(builder: IBuilderUsuario, nombre: string, email: string, depto: string, linea: string)
    +construirUsuarioGeneral(builder: IBuilderUsuario, nombre: string, email: string)
