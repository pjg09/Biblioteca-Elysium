    +{static} Fallido(mensaje : string) : Resultado
}

class ContextoValidacion {
    -string idUsuario
    -string idMaterial
    -Usuario usuario
    -Material material
    -TipoOperacion operacion
    +GetIdUsuario() : string
    +GetIdMaterial() : string
    +GetUsuario() : Usuario
    +GetMaterial() : Material
    +GetOperacion() : TipoOperacion
    +TieneUsuario() : bool
    +TieneMaterial() : bool
}

note right of ContextoValidacion
  Usa String para los IDs porque recibe
  input crudo de la capa de presentación.
  Transporta también las entidades resueltas
  (Usuario, Material) para evitar búsquedas
  repetidas en cada regla de validación.
end note


