@startuml Sistema_Biblioteca_patrones

'ESTILOS


skinparam classAttributeIconSize 0
skinparam roundcorner 10
skinparam shadowing false

skinparam class {
    BackgroundColor<<abstract>> LightYellow
    BackgroundColor<<interface>> LightBlue
    BackgroundColor<<exception>> LightCoral
    BackgroundColor<<enumeration>> LightGreen
    BackgroundColor<<service>> Wheat
    BorderColor Black
    ArrowColor Black
}

' ========================================
' ENTIDADES DEL DOMINIO
' ========================================



' ========================================
' MATERIAL Y SUBCLASES
' ========================================

abstract class Material {
    -string id
    -string titulo
    -string autor
    -TipoMaterial tipo
    -EstadoMaterial estado
    -DateTime fechaAdquisicion
    -double precio
    +GetId() : string
    +GetTitulo() : string
    +GetAutor() : string
    +GetTipo() : TipoMaterial
    +GetEstado() : EstadoMaterial
    +GetPrecio() : double
    +SetPrecio(precio: double)
    +MarcarComoPrestado()
    +MarcarComoDisponible()
    +MarcarComoEnReparacion(motivo: string)
    +MarcarComoPerdido(motivo: string)
    +EstaDisponibleParaPrestamo() : bool
}

class Libro #LightBlue {
    -string isbn
    -int numeroPaginas
    -bool esBestSeller
    -bool esReferencia
    +GetISBN() : string
    +EsBestSeller() : bool
    +EsReferencia() : bool
}

class DVD {
    -string codigo
    -int duracionMinutos
    -string director
    +GetCodigo() : string
}

class Revista {
    -string issn
    -int numeroEdicion
    -bool esUltimoNumero
    +GetISSN() : string
    +EsUltimoNumero() : bool
}

class EBook {
    -string urlDescarga
    -int licenciasDisponibles
    -DateTime fechaVencimientoLicencia
    +GetLicenciasDisponibles() : int
    +TieneLicenciasDisponibles() : bool
}

Material <|-- Libro
Material <|-- DVD
Material <|-- Revista
Material <|-- EBook

' ========================================
' USUARIO Y SUBCLASES
' ========================================

abstract class Usuario {
    -string id
    -string nombre
    -string email
    -TipoUsuario tipo
    -EstadoUsuario estado
    -DateTime fechaRegistro
    +GetId() : string
    +GetNombre() : string
    +GetEmail() : string
    +GetTipo() : TipoUsuario
    +GetEstado() : EstadoUsuario
    +BloquearPorMulta()
    +BloquearPorPerdida()
    +Suspender()
    +Reactivar()
    +PuedeRealizarTransacciones() : bool
}

class Estudiante {
    -string carrera
    -int semestre
    -string universidad
    +GetCarrera() : string
}

class Profesor {
    -string departamento
    -string universidad
    -string especialidad
    +GetDepartamento() : string
}

class Investigador {
    -string lineaInvestigacion
    -string institucion
    +GetLineaInvestigacion() : string
}

class PublicoGeneral {
    -string direccion
    -string nombreFiador
    +GetFiador() : string
}

Usuario <|-- Estudiante
Usuario <|-- Profesor
Usuario <|-- Investigador
Usuario <|-- PublicoGeneral

' ========================================
' TRANSACCIONES
' ========================================

abstract class Transaccion {
    -string id
    -string idUsuario
    -string idMaterial
    -DateTime fechaCreacion
    -EstadoTransaccion estado
    +GetId() : string
    +GetIdUsuario() : string
    +GetIdMaterial() : string
    +GetEstado() : EstadoTransaccion
    +ActualizarEstado(nuevoEstado: EstadoTransaccion)
}

abstract class Prestamo #LightBlue{
    -DateTime fechaPrestamo
    -DateTime fechaDevolucionEsperada
    -DateTime fechaDevolucionReal
    -int renovacionesUsadas
    +GetFechaPrestamo() : DateTime
    +GetFechaDevolucionEsperada() : DateTime
    +GetFechaDevolucionReal() : DateTime
    +SetFechaDevolucionReal(fecha)
    +GetRenovacionesUsadas() : int
    +IncrementarRenovaciones()
}

class PrestamoNormal {
    -string ubicacionBiblioteca
    +GetUbicacion() : string
}

class PrestamoInterbibliotecario {
    -string bibliotecaOrigen
    -string bibliotecaDestino
    -decimal costoTransferencia
    +GetBibliotecaOrigen() : string
    +GetBibliotecaDestino() : string
    +GetCostoTransferencia() : decimal
}

Transaccion <|-- Prestamo
Prestamo <|-- PrestamoNormal
Prestamo <|-- PrestamoInterbibliotecario

abstract class Reserva {
    -DateTime fechaReserva
    -DateTime fechaNotificacion
    -DateTime fechaExpiracion
    -int posicionCola
    +GetFechaReserva() : DateTime
    +GetPosicionCola() : int
    +SetPosicionCola(posicion)
}

class ReservaNormal {
    -string ubicacionBiblioteca
    +GetUbicacion() : string
}

class ReservaInterbibliotecaria {
    -string bibliotecaDestino
    +GetBibliotecaDestino() : string
}

Transaccion <|-- Reserva
Reserva <|-- ReservaNormal
Reserva <|-- ReservaInterbibliotecaria

' ========================================
' MULTAS
' ========================================

abstract class Multa {
    -string id
    -string idPrestamo
    -string idUsuario
    -DateTime fechaGeneracion
    -DateTime fechaPago
    -EstadoMulta estado
    -string motivo
    +GetId() : string
    +GetIdPrestamo() : string
    +GetIdUsuario() : string
    +GetEstado() : EstadoMulta
    +GetMotivo() : string
    +SetFechaPago(fecha)
    +{abstract} CalcularMontoTotal() : decimal
    +EsPendiente() : bool
}

class MultaPorRetraso {
    -int diasRetraso
    -decimal tarifaDiaria
    +GetDiasRetraso() : int
    +CalcularMontoTotal() : decimal
}

class MultaPorDano {
    -List<Dano> danos
    +GetDanos() : List<Dano>
    +CalcularMontoTotal() : decimal
}

class MultaPorPerdida {
    -decimal valorMaterial
    -decimal porcentajeRecargo
    +GetValorMaterial() : decimal
    +CalcularMontoTotal() : decimal
}

Multa <|-- MultaPorRetraso
Multa <|-- MultaPorDano
Multa <|-- MultaPorPerdida

' ========================================
' BUILDERS E INTERFACES DE BUILDERS
' ========================================

' Interfaces de Builders (DIP)
interface IBuilderMaterial {
    +conId(id: string) : IBuilderMaterial
    +conTitulo(titulo: string) : IBuilderMaterial
    +deAutor(autor: string) : IBuilderMaterial
    +conPrecio(precio: double) : IBuilderMaterial
    +esLibro() : IBuilderMaterial
    +esDVD() : IBuilderMaterial
    +esRevista() : IBuilderMaterial
    +esEBook() : IBuilderMaterial
    +construir() : Material
}

interface IBuilderUsuario {
    +conId(id: string) : IBuilderUsuario
    +conNombre(nombre: string) : IBuilderUsuario
    +conEmail(email: string) : IBuilderUsuario
    +esEstudiante(carrera: string, semestre: int, univ: string) : IBuilderUsuario
    +esProfesor(depto: string, univ: string, esp: string) : IBuilderUsuario
    +esInvestigador(lineaInv: string, inst: string) : IBuilderUsuario
    +esPublicoGeneral(dir: string, fiador: string) : IBuilderUsuario
    +construir() : Usuario
}

interface IBuilderPrestamo {
    +paraUsuario(id: string) : IBuilderPrestamo
    +deMaterial(id: string) : IBuilderPrestamo
    +conId(id: string) : IBuilderPrestamo
    +conVencimiento(fecha: DateTime) : IBuilderPrestamo
    +porDias(dias: int) : IBuilderPrestamo
    +tipoNormal() : IBuilderPrestamo
    +tipoInterbibliotecario(origen: string, destino: string, costo: double) : IBuilderPrestamo
    +construir() : Prestamo
}



' Builders concretos
class MaterialBuilder {
    +conId(id: string) : IBuilderMaterial
    +conTitulo(titulo: string) : IBuilderMaterial
    +deAutor(autor: string) : IBuilderMaterial
    +conPrecio(precio: double) : IBuilderMaterial
    +esLibro() : IBuilderMaterial
    +esDVD() : IBuilderMaterial
    +esRevista() : IBuilderMaterial
    +esEBook() : IBuilderMaterial
    +construir() : Material
}

class UsuarioBuilder {
    +conId(id: string) : IBuilderUsuario
    +conNombre(nombre: string) : IBuilderUsuario
    +conEmail(email: string) : IBuilderUsuario
    +esEstudiante(carrera: string, semestre: int, univ: string) : IBuilderUsuario
    +esProfesor(depto: string, univ: string, esp: string) : IBuilderUsuario
    +esInvestigador(lineaInv: string, inst: string) : IBuilderUsuario
    +esPublicoGeneral(dir: string, fiador: string) : IBuilderUsuario
    +construir() : Usuario
}

class PrestamoBuilder {
    +paraUsuario(id: string) : IBuilderPrestamo
    +deMaterial(id: string) : IBuilderPrestamo
    +conId(id: string) : IBuilderPrestamo
    +conVencimiento(fecha: DateTime) : IBuilderPrestamo
    +tipoNormal() : IBuilderPrestamo
    +tipoInterbibliotecario(origen: string, destino: string, costo: double) : IBuilderPrestamo
    +construir() : Prestamo
}



' Director (usa interfaces de builders)
class DirectorCreacion {
    +construirEstudianteBasico(builder: IBuilderUsuario, nombre: string, email: string, carrera: string)
    +construirProfesorInvestigador(builder: IBuilderUsuario, nombre: string, email: string, depto: string, linea: string)
    +construirUsuarioGeneral(builder: IBuilderUsuario, nombre: string, email: string)
    +construirLibroReferencia(builder: IBuilderMaterial, titulo: string, autor: string, isbn: string)
    +construirRevistaMensual(builder: IBuilderMaterial, titulo: string, issn: string, edicion: int)
}

' Implementación de interfaces de builders
IBuilderMaterial <|.. MaterialBuilder
IBuilderUsuario <|.. UsuarioBuilder
IBuilderPrestamo <|.. PrestamoBuilder


' Relaciones de construcción
MaterialBuilder ..> Material : construye
UsuarioBuilder ..> Usuario : construye
PrestamoBuilder ..> Prestamo : construye


' Director usa interfaces de builders
DirectorCreacion --> IBuilderUsuario : usa
DirectorCreacion --> IBuilderMaterial : usa

' RELACIONES ENTRE ENTIDADES

Usuario "1" -- "0..*" Transaccion : realiza
Material "1" -- "0..*" Transaccion : involucrado
Prestamo "1" -- "0..*" Multa : genera
Usuario "1" -- "0..*" Multa : tiene
MultaPorDano "1" *-- "1..*" Dano : contiene

' ========================================
' EXCEPCIONES
' ========================================

class BibliotecaException <<exception>> {
    -string mensaje
    -string codigo
    +GetMensaje() : string
    +GetCodigo() : string
}

class MaterialNoDisponibleException <<exception>> {
    -string idMaterial
    -EstadoMaterial estadoActual
    -DateTime fechaDisponibilidadEstimada
    +GetIdMaterial() : string
    +GetEstadoActual() : EstadoMaterial
}

class UsuarioBloqueadoException <<exception>> {
    -string idUsuario
    -List<string> motivosBloqueo
    -decimal multaPendiente
    +GetIdUsuario() : string
    +GetMotivos() : List<string>
}

class LimiteExcedidoException <<exception>> {
    -string idUsuario
    -int limiteMaximo
    -int cantidadActual
    +GetLimiteMaximo() : int
}

class MaterialNoEncontradoException <<exception>> {
    -string idMaterial
    +GetIdMaterial() : string
}

class OperacionNoPermitidaException <<exception>> {
    -string operacion
    +GetOperacion() : string
}

BibliotecaException <|-- MaterialNoDisponibleException
BibliotecaException <|-- UsuarioBloqueadoException
BibliotecaException <|-- LimiteExcedidoException
BibliotecaException <|-- MaterialNoEncontradoException
BibliotecaException <|-- OperacionNoPermitidaException

' ========================================
' INTERFACES DE SERVICIOS
' ========================================

interface IDisponibilidadService {
    +VerificarDisponibilidad(string : string) : bool
    +ObtenerEstadoActual(string : string) : EstadoMaterial
    +MaterialEsPrestable(string : string, tipoMaterial : TipoMaterial) : bool
}

interface ILimitePrestamoService {
    +ValidarLimite(string : string, tipoUsuario : TipoUsuario) : ResultadoValidacion
    +ObtenerLimiteMaximo(tipoUsuario : TipoUsuario) : int
    +CantidadActualPrestada(string : string) : int
}

interface IValidadorReglasService {
    +ValidarPrestamo(string : string, string : string) : ResultadoValidacion
    +ValidarReserva(string : string, string : string) : ResultadoValidacion
    +ValidarRenovacion(string : string) : ResultadoValidacion
}

note right of IValidadorReglasService
  ValidarRenovacion existe en la interfaz
  y está implementado en ValidadorReglasService,
  pero RenovacionService NO lo usa: tiene su
  propia validación interna desde IRenovacionService.
  Se mantiene para consumidores externos
  que necesiten validar renovación sin ejecutarla.
end note

interface IPoliticaTiempoService {
    +CalcularDiasPrestamo(tipoMaterial : TipoMaterial, tipoUsuario : TipoUsuario) : int
    +ObtenerFechaDevolucion(fechaPrestamo : DateTime, tipoMaterial : TipoMaterial, tipoUsuario : TipoUsuario) : DateTime
}

interface IGestorBloqueoService {
    +VerificarSiDebeBloquear(string : string) : ResultadoValidacion
    +BloquearUsuario(string : string, motivo : string) : Resultado
    +DesbloquearUsuario(string : string) : Resultado
    +ObtenerTotalMultasPendientes(string : string) : BigDecimal
    +TienePrestamosVencidos(string : string) : bool
}

interface IReservaService {
    +CrearReserva(string : string, string : string, tipoReserva : string) : Resultado
    +CancelarReserva(string : string) : Resultado
    +NotificarDisponibilidad(string : string) : Resultado
}

interface IRenovacionService {
    +ValidarRenovacion(string : string) : ResultadoValidacion
    +RenovarPrestamo(string : string) : Resultado
    +ObtenerRenovacionesDisponibles(string : string, tipoUsuario : TipoUsuario) : int
}

interface IPrestamoService {
    +RegistrarPrestamo(string : string, string : string, tipoPrestamo : string) : Resultado
    +ObtenerPrestamosActivos(string : string) : List<Prestamo>
}

interface IDevolucionService {
    +RegistrarDevolucion(string : string, evaluacion : Evaluacion) : Resultado
}



interface INotificacionService {
    +EnviarNotificacion(string : string, mensaje : string) : Resultado
}

' ========================================
' CALCULADORES DE MULTA
' ========================================

interface ICalculadorMulta {
    +Calcular(contexto : ContextoMulta) : Multa
    +PuedeCalcular(contexto : ContextoMulta) : bool
}

class CalculadorMultaPorRetraso <<service>> {
    -IRepositorio<Prestamo> repoPrestamo
    -IRepositorio<Usuario> repoUsuario
    -Map<TipoMaterial, decimal> tarifasPorTipo
    +Calcular(contexto : ContextoMulta) : Multa
    +PuedeCalcular(contexto : ContextoMulta) : bool
    -CalcularDiasRetraso(prestamo : Prestamo, fechaActual : DateTime) : int
    -ObtenerTarifa(tipoMaterial : TipoMaterial) : decimal
}

class CalculadorMultaPorDano <<service>> {
    -ICalculadorCostoDanoService calculadorCosto
    +Calcular(contexto : ContextoMulta) : Multa
    +PuedeCalcular(contexto : ContextoMulta) : bool
}

class CalculadorMultaPorPerdida <<service>> {
    -IRepositorio<Material> repoMaterial
    -IRepositorio<Usuario> repoUsuario
    +Calcular(contexto : ContextoMulta) : Multa
    +PuedeCalcular(contexto : ContextoMulta) : bool
    -calcularValorMaterial(material : Material) : double
}

note right of CalculadorMultaPorPerdida
  El recargo varía por TipoUsuario:
  Estudiante=20%, Profesor=10%,
  Investigador=0%, PúblicoGeneral=30%.
  Usa Material.getPrecio() para obtener
  el valor base del material.
end note

ICalculadorMulta <|.. CalculadorMultaPorRetraso
ICalculadorMulta <|.. CalculadorMultaPorDano
ICalculadorMulta <|.. CalculadorMultaPorPerdida



' SERVICIO GESTOR DE MULTAS

interface IGestorMultasService {
    +CalcularMulta(contexto : ContextoMulta) : Multa
}

class GestorMultasService <<service>> {
    -List<ICalculadorMulta> calculadores
    +RegistrarCalculador(calculador : ICalculadorMulta)
