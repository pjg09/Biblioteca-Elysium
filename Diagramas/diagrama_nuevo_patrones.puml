    +CalcularCosto(dano : Dano) : decimal
    +CalcularCostoTotal(danos : List<Dano>) : decimal
}

class CalculadorCostoDanoService <<service>> {
    -Map<TipoDano, Map<NivelGravedad, decimal>> tarifas
